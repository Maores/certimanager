# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Environment
.env.local
.env*.local

# Claude Code / Octopus local state
.claude/
.claude-octopus/

# One-off scripts with credentials
scripts/*.mjs

# Sensitive files
cookies.txt
skills-lock.json

# AI tool state directories
.agents/
.kiro/
.qwen/
.superpowers/
.windsurf/


# Local video clips (bug reports recorded to share with the AI). Stay local.
*.MP4
*.mp4
*.MOV
*.mov

# Ad-hoc test journey scratch (one-off Playwright scripts dropped at repo root)
tests-journey-tmp/

# Validation reports generated by one-off scripts (cross-reference-report.json IS tracked, so scope tightly)
scripts/validate-*-report.json
