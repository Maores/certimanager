# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Environment
.env.local
.env*.local

# Claude Code / Octopus local state
.claude/
.claude-octopus/

# One-off scripts with credentials
scripts/*.mjs

# Sensitive files
cookies.txt
skills-lock.json

# AI tool state directories
.agents/
.kiro/
.qwen/
.superpowers/
.windsurf/


# Local video clips (bug reports recorded to share with the AI). Stay local.
*.MP4
*.mp4
*.MOV
*.mov

# Ad-hoc test journey scratch (one-off Playwright scripts dropped at repo root)
tests-journey-tmp/

# Validation reports generated by one-off scripts
scripts/validate-*-report.json
scripts/cross-reference-*.json

# Internal-only docs and historical handoff/session/study material — kept locally, not published
docs/internal/
SESSION_HANDOFF.md
docs/session-history-*.md
docs/cross-validation-*.md
docs/notebooklm-*.md

# Office docs typically contain raw data; force opt-in if needed
*.docx
*.doc
*.xlsx
*.xls

# Common credential / private-key files
.npmrc
.aws/
.ssh/
*.key
*.p12
*.pfx

# IDE-local state
.idea/
.vscode/
